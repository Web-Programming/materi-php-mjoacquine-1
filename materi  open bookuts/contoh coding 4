css
:root{
--navbar-bg:#fd4f4f;
--accent:#FFD700;
--btn:#b2c72b;
--btn-hover:#ccff00;
}

/* GLOBAL */
body{
font-family:'Segoe UI',sans-serif;
background:#f5f6fa;
}

.section-space{
margin-top:80px;
}

.hero-box,.about-box,.contact-box{
background:white;
padding:50px;
border-radius:20px;
box-shadow:0 5px 20px rgba(0,0,0,0.1);
}

.hero-title{font-size:40px;}
.hero-subtitle{color:#777;margin-bottom:15px;}

.title-line{
width:60px;
height:4px;
background:#e43f5a;
margin:15px 0;
}

/* NAVBAR */
.navbar{background:var(--navbar-bg);}
.nav-link{color:white !important;font-weight:500;}
.nav-link:hover{color:var(--accent)!important;}

/* BUTTON */
.btn-primary{
background:var(--btn);
border:none;
color:black;
font-weight:600;
}
.btn-primary:hover{background:var(--btn-hover);}

/* PROFILE IMG */
.profile-img{
width:250px;
border-radius:50%;
border:6px solid var(--navbar-bg);
box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

/* CARD */
.custom-card{
border-radius:15px;
overflow:hidden;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

/* FORM */
form input,form textarea{
border-radius:10px;
padding:10px;
}

/* FOOTER */
.footer{
background:var(--navbar-bg);
padding:30px;
color:white;
}

.icon{
color:white;
font-size:22px;
margin:0 10px;
}

.icon:hover{color:var(--accent);}
.copyright{margin-top:10px;font-size:14px;}

console.log("Portfolio aktif");

// scroll ke project
function scrollProject(){
    document.getElementById("project").scrollIntoView({behavior:"smooth"});
}

// tombol sapa
function infoTambahan(){
    alert("Terima kasih sudah mengunjungi portfolio saya 😊");
}

// kirim pesan kontak
function kirimPesan(event){
    event.preventDefault();

    let nama = document.getElementById("nama").value;
    let email = document.getElementById("email").value;
    let pesan = document.getElementById("pesan").value;

    alert("Terima kasih " + nama + "!\nPesan kamu sudah terkirim.");

    document.getElementById("nama").value="";
    document.getElementById("email").value="";
    document.getElementById("pesan").value="";
}

.copyright-small{
font-size:13px;
opacity:0.8;
margin-top:5px;
}

.terms-link{
display:block;
margin-top:10px;
color:#FFD700;
text-decoration:none;
font-weight:600;
}

