:root{
--navbar-bg:#fd4f4f;
--accent:#FFD700;
--btn:#b2c72b;
--btn-hover:#ccff00;
}

body{font-family:'Segoe UI';background:#f5f6fa;}

.section-space{margin-top:80px;}

.hero-box,.about-box,.contact-box{
background:white;
padding:50px;
border-radius:20px;
box-shadow:0 5px 20px rgba(0,0,0,0.1);
}

.navbar{background:var(--navbar-bg);}
.nav-link{color:white!important;font-weight:500;}
.nav-link:hover{color:var(--accent)!important;}

.btn-primary{background:var(--btn);border:none;color:black;font-weight:600;}
.btn-primary:hover{background:var(--btn-hover);}

.profile-img{
width:250px;border-radius:50%;
border:6px solid var(--navbar-bg);
}

.custom-card{border-radius:15px;box-shadow:0 5px 15px rgba(0,0,0,0.1);}

.footer{background:var(--navbar-bg);padding:30px;color:white;}

.copyright-small{font-size:13px;opacity:0.8;}
.terms-link{color:#FFD700;font-weight:600;text-decoration:none;}

