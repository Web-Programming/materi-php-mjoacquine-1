CSS
.nav-custom{
    background:#2e6b2f;
}

.hero{
    background:url('https://images.unsplash.com/photo-1598514982562-9c0b2cb61dc3') center/cover;
    height:90vh;
    color:white;
    display:flex;
    align-items:center;
}

.overlay{
    background:rgba(0,0,0,0.55);
    width:100%;
    height:100%;
    display:flex;
    align-items:center;
}

.section-title{
    color:#2e6b2f;
    font-weight:bold;
}

.card{
    border:none;
    border-radius:15px;
}

.footer{
    background:#5a3419;
    color:white;
}

.footer a{
    color:#ffd54f;
    text-decoration:none;
}

JS 
function scrollAbout(){
    document.getElementById("about")
    .scrollIntoView({behavior:"smooth"});
}

function kirimPesan(e){
    e.preventDefault();
    alert("Pesan berhasil dikirim!");
}