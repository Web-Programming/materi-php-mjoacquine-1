/* Variabel Warna Global */
:root {
    --primary-green: #375534;
    --btn-yellow: #f3ca56;
    --bg-light: #f9f9f9;
    --footer-brown: #4a3b32;
    --card-bg-light: #eef5e9;
}

/* Pengaturan Font Dasar */
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Utilitas Teks Kustom */
.text-primary-green {
    color: var(--primary-green) !important;
}

/* Navbar */
.custom-navbar {
    background-color: var(--primary-green);
}
.navbar-brand, .nav-link {
    color: white !important;
    font-weight: 500;
}
.nav-link:hover {
    color: var(--btn-yellow) !important;
}

/* Hero Section */
.hero-section {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1621506289937-a8e4df240d0b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') no-repeat center center/cover;
    height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
}
.hero-content {
    color: white;
    text-align: center;
}

/* Tombol Kustom (Kuning) */
.btn-custom {
    background-color: var(--btn-yellow);
    color: #333;
    font-weight: bold;
    border-radius: 25px;
    padding: 10px 30px;
    border: none;
    transition: background-color 0.3s ease;
}
.btn-custom:hover {
    background-color: #e0b840;
    color: #333;
}

/* Tentang Section */
.about-img {
    width: 100%;
    border-radius: 50% / 30%; /* Membuat bentuk oval seperti mockup */
    object-fit: cover;
}
.stats-text {
    color: var(--primary-green);
    font-weight: bold;
    font-size: 1.5rem;
}

/* Hasil Panen Section */
.hasil-section {
    background-color: var(--bg-light);
    padding: 50px 0;
}
.card-img-top {
    height: 200px;
    object-fit: cover;
}

/* Hubungi Kami Section */
.contact-form-card {
    background-color: var(--card-bg-light);
    border-radius: 15px;
    padding: 30px;
    border: none;
}

/* Footer Section */
.custom-footer {
    background-color: var(--footer-brown);
    color: white;
    padding: 20px 0;
    font-size: 0.9rem;
}
.footer-muted-text {
    color: #cccccc;
}
.footer-link {
    color: var(--btn-yellow);
    text-decoration: none;
}
.footer-link:hover {
    text-decoration: underline;
}

JS
// Menunggu seluruh dokumen HTML selesai dimuat
document.addEventListener("DOMContentLoaded", function() {
    
    // Mengambil elemen formulir berdasarkan ID
    const contactForm = document.getElementById('contactForm');
    
    // Memastikan elemen formulir ada sebelum menambahkan event listener
    if (contactForm) {
        contactForm.addEventListener('submit', function(event) {
            // Mencegah halaman reload (refresh) saat form disubmit
            event.preventDefault(); 
            
            // Mengambil nilai dari input nama
            const nama = document.getElementById('nama').value;
            
            // Menampilkan notifikasi popup (alert) kepada pengguna
            alert('Halo ' + nama + ', terima kasih! Pesan kerjasama Anda telah berhasil dikirim. Kami akan membalas ke email Anda segera.');
            
            // Mengosongkan isian form setelah disubmit
            this.reset();
        });
    }
    
});

